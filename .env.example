# AI Model API Keys
ANTHROPIC_API_KEY=sk-ant-...
# NOTE: the chat route reads GOOGLE_AI_API_KEY (must match this exact name).
GOOGLE_AI_API_KEY=AIza...
XAI_API_KEY=xai-...
MOONSHOT_API_KEY=sk-...

# GitHub (for repo explorer & handler browser)
GITHUB_TOKEN=ghp_...

# App access gate (shared password). Required — login is blocked without these.
#   APP_PASSWORD : the password you share with trusted users.
#   SESSION_SECRET: random 32+ byte hex used to sign the session cookie.
#                   Generate with: openssl rand -hex 32
APP_PASSWORD=your-strong-shared-password
SESSION_SECRET=replace-with-openssl-rand-hex-32

# Supabase (for saved items persistence)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Note: The database uses an `updated_at` trigger on all tables.
# If setting up a new Supabase project, create this function + trigger:
#
#   CREATE OR REPLACE FUNCTION update_updated_at()
#   RETURNS TRIGGER AS $$
#   BEGIN
#     NEW.updated_at = NOW();
#     RETURN NEW;
#   END;
#   $$ LANGUAGE plpgsql;
#
#   -- Apply to each table:
#   CREATE TRIGGER set_updated_at
#     BEFORE UPDATE ON <table_name>
#     FOR EACH ROW EXECUTE FUNCTION update_updated_at();
